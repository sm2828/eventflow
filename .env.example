# PostgreSQL
POSTGRES_USER=eventflow
POSTGRES_PASSWORD=eventflow_secret
POSTGRES_DB=eventflow

# Redis
REDIS_PASSWORD=redis_secret

# API Keys (comma-separated)
# Generate with: openssl rand -hex 32
API_KEYS=dev_key_123,test_key_456

# Dashboard API key (used by the dashboard to authenticate with the API)
DASHBOARD_API_KEY=dev_key_123
