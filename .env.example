# ── Local development (Docker Compose) ───────────────────────────────────────
POSTGRES_USER=eventflow
POSTGRES_PASSWORD=eventflow_secret
POSTGRES_DB=eventflow
REDIS_PASSWORD=redis_secret

# ── API Keys ──────────────────────────────────────────────────────────────────
# Comma-separated. Add "portfolio_demo_key" for public portfolio use.
API_KEYS=dev_key_123,test_key_456,portfolio_demo_key
DASHBOARD_API_KEY=dev_key_123

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Lower this in production to protect against abuse
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_MS=60000

# ── Production only (not used by Docker Compose) ──────────────────────────────
# DATABASE_URL=postgresql://user:pass@host:5432/dbname   ← from Neon
# REDIS_URL=rediss://user:pass@host:port                 ← from Upstash (note: rediss://)
# CORS_ORIGINS=https://your-dashboard.vercel.app,http://localhost:5173
